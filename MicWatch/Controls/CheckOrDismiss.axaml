<UserControl
    x:Class="MicWatch.Controls.CheckOrDismiss"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ci="http://classisland.tech/schemas/xaml/core"
    xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:MicWatch.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Panel>
        <controls:FontIcon
            FontSize="24"
            FontWeight="Bold"
            Foreground="Green"
            Glyph="&#xE423;"
            IsVisible="{Binding Status, ElementName=Root}" />
        <controls:FontIcon
            FontSize="24"
            FontWeight="Bold"
            Foreground="Red"
            Glyph="&#xE670;"
            IsVisible="{Binding !Status, ElementName=Root}" />
    </Panel>
</UserControl>
